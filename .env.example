# Team bootstrap defaults
# Copy this to .env and adjust if needed.

# Primary site used by start scripts
SITE_NAME=crysomedia.erp.local
SITE_ADMIN_PASSWORD=admin

# Local MariaDB root credentials used for non-interactive central site reset
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3307
LOCAL_DB_ROOT_USER=root
LOCAL_DB_ROOT_PASSWORD=root
MARIADB_USER_HOST_LOGIN_SCOPE=%

# External DB settings for tenant provisioning (saas_control API)
SAAS_DB_HOST=162.19.221.228
SAAS_DB_PORT=3308
SAAS_DB_ROOT_USER=root
SAAS_DB_ROOT_PASSWORD=admin

# Optional: if your MariaDB runs in Docker locally, keep this container name.
SAAS_DB_CONTAINER=erp-mariadb
SAAS_ERP_APP=erpnext
SAAS_BASE_DOMAIN=erp.local

# Redirect mode: auto | nip_io | native
SAAS_REDIRECT_MODE=nip_io
